# Vercel Redis/KV (chỉ cần 1 cặp biến)
# Cặp cũ của @vercel/kv:

KV_REST_API_URL=
KV_REST_API_TOKEN=

# Cặp Upstash mới:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Một số project tạo theo tên REDIS_*:
REDIS_URL=
REDIS_TOKEN=

# Bí mật Vercel Cron (Project Settings → Cron Jobs → CRON_SECRET)
CRON_SECRET=

# Tuỳ chọn: bắt buộc cho POST /api/report từ web (nhập cùng giá trị trong UI "Admin secret")
ADMIN_SECRET=
