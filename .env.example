# Redis (bắt buộc)
REDIS_URL=
# Có thể bỏ trống nếu token đã nằm trong REDIS_URL
REDIS_TOKEN=

# Bí mật Vercel Cron (Project Settings → Cron Jobs → CRON_SECRET)
CRON_SECRET=

# Tuỳ chọn: bắt buộc cho POST /api/report từ web (nhập cùng giá trị trong UI "Admin secret")
ADMIN_SECRET=

# Đăng nhập web (bắt buộc nếu bật middleware đăng nhập)
AUTH_USERNAME=
AUTH_PASSWORD=
AUTH_SECRET=
