# Supabase (bắt buộc - thay thế Redis)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Redis (tùy chọn - dùng tạm để migration, sau đó có thể xóa)
REDIS_URL=
REDIS_TOKEN=

# Bí mật Vercel Cron (Project Settings → Cron Jobs → CRON_SECRET)
CRON_SECRET=

# Tuỳ chọn: bắt buộc cho POST /api/report từ web (nhập cùng giá trị trong UI "Admin secret")
ADMIN_SECRET=

# Đăng nhập web (bắt buộc)
AUTH_SECRET=

# Tùy chọn: tự seed super admin đầu tiên khi chưa có user nào
AUTH_BOOTSTRAP_ADMIN_ID=
AUTH_BOOTSTRAP_ADMIN_PASSWORD=
