# Vercel: tạo KV database, gán vào project — tự điền KV_REST_API_URL / KV_REST_API_TOKEN

KV_REST_API_URL=
KV_REST_API_TOKEN=

# Bí mật Vercel Cron (Project Settings → Cron Jobs → CRON_SECRET)
CRON_SECRET=

# Tuỳ chọn: bắt buộc cho POST /api/report từ web (nhập cùng giá trị trong UI "Admin secret")
ADMIN_SECRET=
